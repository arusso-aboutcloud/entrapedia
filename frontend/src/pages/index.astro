---
import Base from '../layouts/Base.astro';
import { CATEGORIES, CATEGORY } from '../lib/categories.mjs';
import { getCollection } from 'astro:content';

const all = await getCollection('articles');
const visible = all.sort((a, b) => a.data.title.localeCompare(b.data.title));
const countByCat = {};
for (const a of visible) countByCat[a.data.category] = (countByCat[a.data.category] || 0) + 1;
const featured = visible.filter((a) => a.data.featured);
const legacy = visible.filter((a) => a.data.layer === 'legacy');
const startHere = visible.find((a) => a.data.category === 'fundamentals') || featured[0] || visible[0];

const card = (a) => a; // articles passed straight to markup below
---
<Base title="Entrapedia - the curated Microsoft Entra ID encyclopedia">
  <section class="hero boot b3">
    <span class="tag">the entra id encyclopedia</span>
    <h1>Microsoft Entra ID, <span class="hl">explained and interlinked</span> &mdash; authored concept articles, grounded in the official corpus, threaded with the Azure AD heritage story.</h1>
    <p class="hero-sub">Not a search box and a results list. A body of curated, browsable articles with a sense of place &mdash; each one part authored editorial, part cited evidence. Wander the nine categories, or jump to a core concept.</p>
    <div class="hero-actions">
      {startHere && <a class="btn-primary" href={`/a/${startHere.data.slug}`}>Start here &rarr;</a>}
      <a class="btn-ghost" href="#heritage">The Azure AD heritage lens</a>
      <a class="btn-ghost" href="/search">Search the corpus (utility)</a>
    </div>
  </section>

  <section class="catgrid-wrap">
    <span class="tag">browse by category</span>
    <div class="catgrid">
      {CATEGORIES.map((c) => (
        <a class="catcard" href={`/c/${c.id}`}>
          <span class="cc-n">{c.n}</span>
          <span class="cc-label">{c.label}</span>
          <span class="cc-blurb">{c.blurb}</span>
          <span class="cc-count">{countByCat[c.id] ? `${countByCat[c.id]} article${countByCat[c.id] === 1 ? '' : 's'}` : 'authoring soon'}</span>
        </a>
      ))}
    </div>
  </section>

  {featured.length > 0 && (
    <section class="feat-wrap">
      <span class="tag">core concepts</span>
      <div class="feat">
        {featured.map((a) => (
          <a class={`featcard ${a.data.layer === 'legacy' ? 't-legacy' : 't-official'}`} href={`/a/${a.data.slug}`}>
            <div class="fc-top">
              <span class="badge kind">{CATEGORY[a.data.category]?.label || a.data.category}</span>
              {a.data.layer === 'legacy' && <span class="stamp">heritage</span>}
              {a.data.draft && <span class="draftflag">draft exemplar</span>}
            </div>
            <h3 class="fc-title">{a.data.title}</h3>
            <p class="fc-sum">{a.data.summary}</p>
            <span class="fc-go">Read &rarr;</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="heritage-wrap" id="heritage">
    <span class="tag">heritage / formerly known as</span>
    <div class="heritage-box">
      <p>Entrapedia threads the <b>Azure AD &rarr; Microsoft Entra ID</b> lineage through every article &mdash; renamed features, retired products, and deprecated-with-modern-equivalent. Legacy content carries a distinct archival treatment so the evolution reads at a glance.</p>
      {legacy.length > 0 && (
        <div class="heritage-list">
          {legacy.map((a) => (
            <a class="hl-item" href={`/a/${a.data.slug}`}><span class="stamp">archive</span> {a.data.title}</a>
          ))}
        </div>
      )}
    </div>
  </section>

  <section class="legend-wrap">
    <span class="tag">how to read entrapedia</span>
    <div class="legend">
      <div class="item o"><div class="lt">&#9679; authored + official</div><p>Editorial voice over Microsoft-published evidence. Cyan glow = authoritative/current.</p></div>
      <div class="item l"><div class="lt">&#9632; legacy / heritage</div><p>Azure AD lineage &mdash; renamed, deprecated, formerly-known-as. Amber archival treatment.</p></div>
      <div class="item c"><div class="lt">&#9633; community</div><p>Attributed third-party evidence (e.g. licensing matrices), flagged <em>verify against Microsoft</em>. Never outranks official.</p></div>
    </div>
  </section>
</Base>
