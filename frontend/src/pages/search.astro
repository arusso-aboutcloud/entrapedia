---
import Base from '../layouts/Base.astro';
import { SAMPLES, SAMPLE_ADVISORY } from '../lib/site.mjs';
const examples = [
  'what permission do I need to read all users',
  'User.Read.All',
  'require MFA with conditional access',
  'least privilege to list applications',
  'df021288-bdef-4463-88db-98f22de89214',
];
const bootstrap = { samples: SAMPLES, advisory: SAMPLE_ADVISORY };
const crumbs = [{ label: 'Home', href: '/' }, { label: 'Search' }];
---
<Base title="Entrapedia - search the corpus" breadcrumbs={crumbs}>
  <section class="searchwrap boot b3">
    <span class="tag">search the corpus &mdash; a utility</span>
    <h1>Search is the <span class="hl">evidence layer</span>, not the front door. For concepts, <a href="/">browse the encyclopedia</a>. To look something up, ask in plain language or paste an exact <span class="hl">permission name</span> or <span class="hl">GUID</span> &mdash; results are retrieved and <span class="hl">cited</span>, never generated.</h1>

    <form class="searchbox" id="searchform" role="search" autocomplete="off">
      <span class="prompt" aria-hidden="true">&gt;</span>
      <input id="q" name="q" type="search" inputmode="search" maxlength="256"
             placeholder="e.g. what permission to read all users" aria-label="Search the Entra corpus" />
      <button type="submit">Search</button>
    </form>

    <div class="examples">
      <span class="lbl">try</span>
      {examples.map((e) => <button class="chip" data-q={e}>{e}</button>)}
    </div>
  </section>

  <section class="results" id="resultsSection" aria-live="polite">
    <div class="meta" id="resultMeta"></div>
    <div id="advisorySlot"></div>
    <div id="results"></div>
  </section>

  <script type="application/json" id="bootstrap" set:html={JSON.stringify(bootstrap)} />

  <script>
    const $ = (s, r = document) => r.querySelector(s);
    const boot = JSON.parse($('#bootstrap').textContent);
    const esc = (s) => String(s == null ? '' : s).replace(/[&<>"']/g, (c) => (
      { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
    const TRUST = {
      official: { cls: 't-official', label: 'official' },
      community: { cls: 't-community', label: 'community' },
      legacy: { cls: 't-legacy', label: 'legacy' },
    };
    function trustOf(r) {
      if (r.layer === 'legacy' || r.trust === 'legacy') return TRUST.legacy;
      return TRUST[r.trust] || TRUST.community;
    }
    function cardHTML(r, i) {
      const t = trustOf(r);
      const kind = (r.result_kind || 'doc').toUpperCase();
      const rank = String(i + 1).padStart(2, '0');
      const flag = t === TRUST.community
        ? '<span class="verify">&#9888; verify vs microsoft</span>'
        : (t === TRUST.legacy ? '<span class="stamp">archive</span>' : '');
      let perm = '';
      if (r.result_kind === 'permission' && r.permission) {
        const pv = (r.privilege != null) ? `priv ${r.privilege}` : '';
        const guid = r.app_guid || r.delegated_guid || '';
        perm = `<div class="perm"><span class="name">${esc(r.permission)}</span>`
          + (guid ? `<span class="guid">${esc(guid)}</span>` : '')
          + (r.principal ? `<span class="pv">${esc(r.principal)}</span>` : '')
          + (pv ? `<span class="pv">${esc(pv)}</span>` : '')
          + `</div>`;
      }
      const c = r.citation || {};
      const cite = `<div class="cite"><span class="lbl">source</span>`
        + (c.source_url ? `<a href="${esc(c.source_url)}" target="_blank" rel="noopener">${esc((c.source_url||'').replace(/^https?:\/\//,''))}</a>` : '<span class="lic">unknown</span>')
        + (c.license ? `<span class="lic">/ ${esc(c.license)}</span>` : '')
        + (c.attribution ? `<span class="attr">${esc(c.attribution)}</span>` : '')
        + `</div>`;
      const docLink = r.doc_id ? `/doc/?id=${encodeURIComponent(r.doc_id)}` : null;
      const titleHTML = docLink
        ? `<a href="${docLink}">${esc(r.doc_title || r.permission || r.doc_id)}</a>`
        : esc(r.doc_title || r.permission || '');
      const score = (r.reranked_score != null) ? r.reranked_score : (r.score != null ? r.score : '');
      return `<article class="card ${t.cls}">`
        + `<span class="corner">result ${rank}${score!=='' ? ' &middot; '+esc(score) : ''}</span>`
        + `<div class="row1"><span class="badge ${t.cls}">${esc(t.label)}</span><span class="badge kind">${esc(kind)}</span>${flag}</div>`
        + `<div class="title">${titleHTML}</div>${perm}`
        + `<div class="snippet">${esc(r.snippet || '')}</div>${cite}</article>`;
    }
    function advisoryHTML(a) {
      if (!a || a.grounded) return '';
      return `<div class="advisory" role="note"><div class="h">advisory &mdash; not an asserted answer</div><p>${esc(a.note)}</p></div>`;
    }
    function render(data, opts = {}) {
      const results = data.results || [];
      const meta = $('#resultMeta');
      const bits = [];
      if (opts.sample) bits.push('<b>sample</b> &mdash; illustrative result set');
      else {
        bits.push(`<span>query: <b>${esc(opts.query || data.query || '')}</b></span>`);
        bits.push(`<span>${results.length} result${results.length===1?'':'s'}</span>`);
        if (data.short_circuit) bits.push('<span>match: <b>exact identifier</b> &middot; 0 neurons</span>');
        else if (data.identifier_match) bits.push('<span>match: <b>identifier + dense</b></span>');
        if (typeof data.neurons === 'number') bits.push(`<span>${data.neurons} neuron${data.neurons===1?'':'s'}</span>`);
        if (data.cache_hit) bits.push('<span>cache: <b>hit</b></span>');
      }
      meta.innerHTML = bits.join('');
      $('#advisorySlot').innerHTML = advisoryHTML(data.advisory);
      $('#results').innerHTML = results.length
        ? results.map(cardHTML).join('')
        : '<div class="notice">No results. Try a permission name, a GUID, or plainer wording.</div>';
    }
    async function search(q) {
      q = (q || '').trim(); if (!q) return;
      $('#q').value = q;
      const url = new URL(location.href); url.searchParams.set('q', q); history.replaceState(null, '', url);
      $('#resultMeta').innerHTML = '<span class="spinner"></span> retrieving &amp; citing...';
      $('#advisorySlot').innerHTML = ''; $('#results').innerHTML = '';
      try {
        const res = await fetch('/api/search?q=' + encodeURIComponent(q) + '&top_k=8', { headers: { accept: 'application/json' } });
        if (res.status === 429) { $('#resultMeta').innerHTML = '<span class="notice err">Rate limit reached &mdash; please wait a moment and retry.</span>'; return; }
        if (!res.ok) { $('#resultMeta').innerHTML = `<span class="notice err">Search unavailable (HTTP ${res.status}).</span>`; return; }
        render(await res.json(), { query: q });
      } catch (e) { $('#resultMeta').innerHTML = '<span class="notice err">Network error reaching the search proxy.</span>'; }
    }
    $('#searchform').addEventListener('submit', (e) => { e.preventDefault(); search($('#q').value); });
    document.querySelectorAll('.chip').forEach((c) => c.addEventListener('click', () => search(c.dataset.q)));
    const initial = new URLSearchParams(location.search).get('q');
    if (initial) search(initial);
    else render({ results: boot.samples, advisory: boot.advisory }, { sample: true });
  </script>
</Base>
