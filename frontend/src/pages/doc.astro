---
import Base from '../layouts/Base.astro';
---
<Base title="Entrapedia — document">
  <section class="docwrap">
    <a class="tag" href="/" style="display:inline-block;margin-bottom:18px;">&larr; back to search</a>
    <div id="docroot">
      <div class="notice"><span class="spinner"></span> loading document...</div>
    </div>
  </section>

  <script>
    const $ = (s, r = document) => r.querySelector(s);
    const esc = (s) => String(s == null ? '' : s).replace(/[&<>"']/g, (c) => (
      { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));

    function trustClass(d) {
      if (d.layer === 'legacy') return { cls: 't-legacy', label: 'legacy / heritage' };
      if (d.trust === 'community') return { cls: 't-community', label: 'community' };
      return { cls: 't-official', label: 'official' };
    }

    function attribution(d) {
      const c = d.citation || {};
      return `<div class="attribution"><span class="lbl">source attribution &mdash; required on every page (DESIGN.md &sect;4)</span>`
        + `<div class="grid">`
        + `<div>source<br><b>${esc(d.source_label || d.source || '')}</b></div>`
        + `<div>license<br><b>${esc(c.license || 'unknown')}</b></div>`
        + `<div>original<br><a href="${esc(c.source_url || '#')}" target="_blank" rel="noopener">${esc((c.source_url||'').replace(/^https?:\/\//,'') || 'n/a')}</a></div>`
        + `</div>`
        + (c.attribution ? `<div style="margin-top:8px;color:var(--ink-dim)">${esc(c.attribution)}</div>` : '')
        + `</div>`;
    }

    function renderDoc(d) {
      const t = trustClass(d);
      const root = $('#docroot');
      root.innerHTML =
        `<div class="dochead ${t.cls}">`
          + `<div class="badges"><span class="badge ${t.cls}">${esc(t.label)}</span>`
          + (d.layer === 'legacy' ? '<span class="stamp">archive</span>' : '')
          + `<span class="badge kind">DOC</span></div>`
          + `<h1>${esc(d.title || d.doc_id)}</h1>`
        + `</div>`
        + `<div class="section-rule"><span class="tag">current state</span><hr></div>`
        + `<div class="doc-body">${d.html || '<p class="notice">No renderable content.</p>'}</div>`
        + `<div class="section-rule"><span class="tag">history / formerly known as</span><hr></div>`
        + `<div class="history-placeholder">`
          + `<p>The Azure AD &rarr; Entra ID heritage layer for this concept &mdash; rename timeline, deprecated equivalents, and "formerly known as" notes &mdash; renders here.</p>`
          + `<p class="mono">// per DESIGN.md &sect;7: each concept page carries a current-state section and a history section. The heritage layer is a later content chunk; this slot is reserved in the page model now.</p>`
        + `</div>`
        + attribution(d);
    }

    async function load() {
      const id = new URLSearchParams(location.search).get('id');
      if (!id) { $('#docroot').innerHTML = '<div class="notice err">No document id. <a href="/">Return to search.</a></div>'; return; }
      try {
        const res = await fetch('/api/doc?id=' + encodeURIComponent(id), { headers: { accept: 'application/json' } });
        if (!res.ok) { $('#docroot').innerHTML = `<div class="notice err">Could not load document (HTTP ${res.status}). <a href="/">Back to search.</a></div>`; return; }
        const data = await res.json();
        document.title = 'Entrapedia — ' + (data.title || id);
        renderDoc(data);
      } catch (e) {
        $('#docroot').innerHTML = '<div class="notice err">Network error loading the document.</div>';
      }
    }
    load();
  </script>
</Base>
